# Puerto en el que correrá este microservicio Node.js
PORT=3000

# URL del webhook del backend en Python (Flask)
# Cambia el puerto/ruta según donde esté levantado tu Flask
FLASK_WEBHOOK_URL=http://localhost:5000/webhook

# URL de conexión a tu base de datos MongoDB (para guardar la sesión de WhatsApp)
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
